FROM alpine:3.19

# Install runtime dependencies
RUN apk add --no-cache \
    ca-certificates \
    tzdata

# Copy cbox-init binary
COPY build/cbox-init-linux-amd64 /usr/local/bin/cbox-init
RUN chmod +x /usr/local/bin/cbox-init

# Copy test configuration
COPY tests/integration/test-config.yaml /etc/cbox-init/cbox-init.yaml

# Run tests
COPY tests/integration/run-tests.sh /run-tests.sh
RUN chmod +x /run-tests.sh

CMD ["/run-tests.sh"]
